# SQLite (varsayılan — geliştirme)
DATABASE_URL="file:../.roomio-data/roomio.db"

# PostgreSQL (production) — docker compose up -d sonrası:
# DATABASE_URL="postgresql://roomio:roomio@127.0.0.1:5432/roomio?schema=public"

# Redis (çoklu instance oturum / JWT revoke) — docker compose up -d sonrası:
# REDIS_URL="redis://127.0.0.1:6379"

# JWT
ROOMIO_JWT_SECRET="roomio-dev-jwt-secret-change-in-production"

# Canlı entegrasyon testleri (simülasyon kapalı)
# ROOMIO_INTEGRATION_LIVE=1

# Elektra modül gateway URL'leri (canlı modda HTTP health ping)
# Kanal yöneticisi — canlı OTA bridge (Booking/Expedia push-pull)
# ROOMIO_CHANNEL_GATEWAY_URL="https://your-bridge.example.com/channel"
# POST /test ve POST /sync uçları JSON kabul eder (bkz. lib/integrations/channel-manager/adapters/gateway.ts)
# ROOMIO_BOOKING_GATEWAY_URL="https://your-bridge/booking/health"
# ROOMIO_EFATURA_GATEWAY_URL="https://your-bridge/efatura/health"
# ROOMIO_GUEST_PORTAL_GATEWAY_URL="https://your-bridge/guest/health"
# ROOMIO_WHATSAPP_GATEWAY_URL="https://your-bridge/whatsapp/health"
# ROOMIO_REPUTATION_GATEWAY_URL="https://your-bridge/reputation/health"
# ROOMIO_BANKING_GATEWAY_URL="https://your-bridge/banking/health"
# ROOMIO_TOUR_OPERATOR_GATEWAY_URL="https://your-bridge/tour-operator/health"
# ROOMIO_VIOFUN_GATEWAY_URL="https://your-bridge/viofun/health"
# ROOMIO_AI_GATEWAY_URL="https://your-bridge/ai/health"
# ROOMIO_MARINA_GATEWAY_URL="https://your-bridge/marina/health"
# ROOMIO_HR_PORTAL_GATEWAY_URL="https://your-bridge/hr/health"
# ROOMIO_VIRTUAL_POS_GATEWAY_URL="https://your-bridge/vpos/health"
# ROOMIO_GOOGLE_BACKUP_GATEWAY_URL="https://your-bridge/bigquery/health"
# ROOMIO_EDISPATCH_GATEWAY_URL="https://your-bridge/e-dispatch/health"
# ROOMIO_ID_READER_GATEWAY_URL="https://your-bridge/id-reader/health"

# Web Push (HK bildirimleri) — npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:hk@hotelsapphire.com"

# Opsiyonel APM
# SENTRY_DSN=""
