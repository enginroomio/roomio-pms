# Production ortam değişkenleri (docker compose -f docker-compose.prod.yml up)

ROOMIO_JWT_SECRET=replace-with-long-random-secret
ROOMIO_AUTH_REQUIRED=1
POSTGRES_PASSWORD=roomio

# SQLite (tek konteyner test) veya PostgreSQL:
# DATABASE_URL=postgresql://roomio:roomio@postgres:5432/roomio?schema=public
DATABASE_URL=file:/data/roomio.db

REDIS_URL=redis://redis:6379

# Opsiyonel
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# REDIS_URL=redis://...
# PRISMA_SCHEMA=postgresql

# Profesyonel PMS modülleri (kanal, RMS, sadakat, grup)
# ROOMIO_INTEGRATION_LIVE=1
# ROOMIO_CHANNEL_GATEWAY_URL=https://channel-bridge.example.com/sync
# ROOMIO_BOOKING_GATEWAY_URL=https://booking-bridge.example.com/reserve

# Canlı domain (Fly/Render TLS sonrası — deploy readiness HTTPS kontrolü)
# ROOMIO_PUBLIC_URL=https://pms.roomio.io
# ROOMIO_PRODUCTION_URL=https://pms.roomio.io

# EGM/KBS gateway (canlı bildirim)
# ROOMIO_EGM_GATEWAY_URL=https://kbs.example.gov.tr/api/identity
# ROOMIO_EGM_API_KEY=
# ROOMIO_EGM_FACILITY_CODE=SAPPHIRE
# ROOMIO_EGM_LIVE=1

# Fly.io secrets (fly secrets set ... -a roomio-pms)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@hotelsapphire.com

# Render — özel domain (opsiyonel, kod relative URL kullanır)
# ROOMIO_PUBLIC_URL=https://pms.roomio.io
# ROOMIO_CUSTOM_DOMAIN=pms.roomio.io

# Production'da demo auth kapatın
# ROOMIO_DEMO_AUTH=0

# Bulut yedekleme (Google Drive / S3 / webhook gateway)
# ROOMIO_INTEGRATION_LIVE=1
# ROOMIO_CLOUD_BACKUP_GATEWAY_URL=http://127.0.0.1:3921
# ROOMIO_S3_BACKUP_GATEWAY_URL=http://127.0.0.1:3921
# Harici disk yedek (Mac USB — örn. SanDisk, exFAT/APFS)
# ROOMIO_BACKUP_DIR=/Volumes/SanDisk/roomio-backups
# Referans gateway: npm run gateway:backup
