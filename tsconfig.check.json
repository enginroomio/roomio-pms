{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "files": [
    "next-env.d.ts",
    "lib/dashboard/home-layout.ts",
    "lib/dashboard/home-templates.ts",
    "components/dashboard/HomeDesignWizard.tsx",
    "components/DashboardHome.tsx"
  ]
}
