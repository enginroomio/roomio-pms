  validFrom  String?
  validTo    String?
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model RateCalendarEntry {
  id           String   @id
  propertyId   String
  date         String
  ratePlanCode String
  roomType     String?
  rate         Float
  currency     String   @default("TRY")
  property     Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, date, ratePlanCode, roomType])
