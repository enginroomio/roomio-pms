  adultPrice  Float
  childPrice  Float
  seasonName  String
  currency    String   @default("TRY")
  property    Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, mealPlan, roomType, seasonName])
}

model HotelSeason {
  id         String   @id
  propertyId String
  code       String
  name       String
  start      String
  end        String
  active     Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model ConfigParam {
  id          String   @id
  propertyId  String
  key         String
  value       String
  description String
  property    Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, key])
}

model Warehouse {
  id         String   @id
  propertyId String
  code       String
  name       String
  location   String
  active     Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model FiscalDevice {
  id         String   @id
  propertyId String
  code       String
  name       String
  serial     String
  active     Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model PropertyBranch {
  id         String   @id
  propertyId String
  code       String
  name       String
  city       String
  rooms      Int
  active     Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model UserGroup {
  id                  String   @id
  propertyId          String
  code                String
  name                String
  userCount           Int      @default(0)
  description         String?
  permissions         String?
  /**
   * Rolün varsayılan izinlerinden ÇIKARILACAK izinler (JSON dizi, Permission[]).
   * `permissions` alanı sadece EKLEME yapar (union); bu alan ise rolün
   * varsayılanından daha kısıtlı özel roller oluşturmayı sağlar (örn. "kasa
   * erişimi olmayan resepsiyonist"). Bkz. lib/server/user-groups.ts ->
   * resolvePermissionsForUser. Boş/null ise hiçbir izin çıkarılmaz (eski
   * davranışla tam geriye dönük uyumlu).
   */
  excludedPermissions String?
  active              Boolean  @default(true)
  property            Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model PropertyFloor {
  id         String   @id
  propertyId String
  floor      Int
  start      Int
  end        Int
  active     Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, floor])
}

model RoomTypeDefinition {
  id          String   @id
  propertyId  String
  code        String
  short       String
  name        String
  description String?
  location    String?
  bedType     String
  maxPersons  Int
  maxAdults   Int
  maxChildren Int      @default(0)
  baseRate    Float
  specialInfo String?
  active      Boolean  @default(true)
  property    Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}

model PropertyRoom {
  id         String   @id
  propertyId String
  roomNo     String
  floor      Int
  typeCode   String
  location   String?
  building   String   @default("Ana Bina")
  isActive   Boolean  @default(true)
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, roomNo])
}

model UserParam {
  id          String   @id
  propertyId  String
  key         String
  value       String
  description String
  property    Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, key])
}

model EmailOutbox {
  id         String   @id
  propertyId String
  to         String
  subject    String
  body       String
  attachment String?
  status     String
  sentAt     String?
  error      String?
  createdAt  String
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, status])
}

model AgencyContract {
  id          String   @id
  propertyId  String
  code        String
  name        String
  commission  Float
  contractEnd String?
  market      String?
  active      Boolean  @default(true)
  property    Property @relation(fields: [propertyId], references: [id])

  @@unique([propertyId, code])
}
