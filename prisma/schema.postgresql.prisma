}

model GuestComplaint {
  id          String   @id
  propertyId  String
  date        String
  roomNo      String
  guest       String
  category    String
  description String
  priority    String
  status      String
  resolvedAt  String?
  createdAt   String
  property    Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, status])
}

model VipGuest {
  id            String   @id
  propertyId    String
  level         String
  guestName     String
